{
	"$schema": "https://json.schemastore.org/tmLanguage.json",
	"name": "AWK Regular Expressions",
	"scopeName": "source.awk.regexp",
	"injectionSelector": "L:string.regexp.awk -meta.embedded.awk.regexp, L:string.regexp.awk -meta.embedded.awk.regexp, L:string.regexp.awk -meta.embedded.awk.regexp",
	"patterns": [
		{
			"begin": "(?<=/)(?!/|$)",
			"end": "(?=/|$)",
			"name": "meta.embedded.awk.regexp",
			"contentName": "string.regexp.awk",
			"patterns": [ { "include": "#regexp" } ]
		}
	],
	"repository": {
		"regexp": {
			"patterns": [
				{
					"match": "\\\\[Bb]|[$^]",
					"name": "keyword.control.anchor.regexp.awk"
				},
				{
					"match": "\\\\([1-9][0-9]*)",
					"captures": {
						"0": { "name": "keyword.other.back-reference.regexp.awk" },
						"1": { "name": "constant.numeric.regexp.awk" }
					}
				},
				{
					"begin": "\\\\k<?",
					"end": ">|(?=/)|$",
					"name": "keyword.other.back-reference.regexp.awk",
					"patterns": [
						{
							"match": "[$_[:alpha:]][$_[:alnum:]]*",
							"name": "variable.other.regexp.awk"
						}
					]
				},
				{
					"match": "\\G(?>[*+?]|{(?>\\d+,?\\d*|,\\d+)}\\??)",
					"name": "invalid.illegal.keyword.operator.quantifier.regexp.awk"
				},
				{
					"match": "[*+?]",
					"name": "keyword.operator.quantifier.regexp.awk"
				},
				{
					"match": "({(?>\\d+,?\\d*|,\\d+)}\\??)",
					"captures": {
						"0": { "name": "meta.embedded.quantifier.range.regexp.awk" },
						"1": { "name": "keyword.operator.quantifier.regexp.awk" }
					}
				},
				{
					"match": "\\|",
					"name": "keyword.operator.or.regexp.awk"
				},
				{
					"match": "\\.",
					"name": "constant.character.class.regexp.awk"
				},
				{
					"match": "\\)",
					"name": "meta.embedded.group.regexp.awk",
					"captures": { "0": { "name": "invalid.illegal.unclosed.group.regexp.awk" } }
				},
				{
					"begin": "(\\()((\\?=)|(\\?!)|(\\?<=)|(\\?<!))",
					"end": "\\)|(?=/)|$",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.group.regexp.awk" },
						"2": { "name": "punctuation.definition.group.assertion.regexp.awk" },
						"3": { "name": "meta.assertion.look-ahead.regexp.awk" },
						"4": { "name": "meta.assertion.negative-look-ahead.regexp.awk" },
						"5": { "name": "meta.assertion.look-behind.regex.regexp.awk" },
						"6": { "name": "meta.assertion.negative-look-behind.regex.regexp.awk" }
					},
					"endCaptures": { "0": { "name": "punctuation.definition.group.regexp.awk" } },
					"name": "meta.embedded.group.assertion.regexp.awk",
					"contentName": "string.regexp.awk",
					"patterns": [ { "include": "#regexp" } ]
				},
				{
					"begin": "\\((?>(\\?([-ims]*):)|\\?<([$_[:alpha:]][$_[:alnum:]]*)>)?",
					"end": "\\)|(?=/)|$",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.group.regexp.awk" },
						"1": { "name": "punctuation.definition.group.no-capture.regexp.awk" },
						"2": { "name": "keyword.other.flags.regexp.awk" },
						"3": { "name": "variable.other.regexp.awk" }
					},
					"endCaptures": { "0": { "name": "punctuation.definition.group.regexp.awk" } },
					"name": "meta.embedded.group.regexp.awk",
					"contentName": "string.regexp.awk",
					"patterns": [ { "include": "#regexp" } ]
				},
				{
					"begin": "(\\[)(\\^)?",
					"end": "]|$",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.character-class.regexp.awk" },
						"2": { "name": "keyword.operator.negation.regexp.awk" }
					},
					"endCaptures": { "0": { "name": "punctuation.definition.character-class.regexp.awk" } },
					"name": "meta.embedded.character-class.regexp.awk",
					"contentName": "constant.other.character-class.set.regexp.regex.awk",
					"patterns": [
						{
							"match": "[0-9]-[0-9]",
							"name": "constant.numeric.character-class.range.regexp.awk"
						},
						{
							"match": "[a-z]-[a-z]|[A-Z]-[A-Z]",
							"name": "variable.other.constant.character-class.range.regexp.awk"
						},
						{
							"match": "(?>(\\\\(?>[0-7]{3}|x\\h{2}|u\\h{4}))|(\\\\c[A-Z])|(\\\\[^wWsSdD])|.)-(?>(\\\\(?>[0-7]{3}|x\\h{2}|u\\h{4}))|(\\\\c[A-Z])|(\\\\[^wWsSdD])|[^]])",
							"captures": {
								"0": { "name": "support.class.range.regexp.awk" },
								"1": { "name": "constant.character.numeric.regexp.awk" },
								"2": { "name": "constant.character.control.regexp.awk" },
								"3": { "name": "constant.character.escape.backslash.regexp.awk" },
								"4": { "name": "constant.character.numeric.regexp.awk" },
								"5": { "name": "constant.character.control.regexp.awk" },
								"6": { "name": "constant.character.escape.backslash.regexp.awk" }
							},
							"name": "constant.other.character-class.range.regexp.awk"
						},
						{ "include": "#regex-character-class" }
					]
				},
				{ "include": "#regex-character-class" }
			]
		},
		"regex-character-class": {
			"patterns": [
				{
					"match": "\\\\(?>[0-7]{3}|x\\h{2}|u\\h{4})",
					"name": "constant.character.numeric.regexp.awk"
				},
				{
					"match": "\\\\[wWsSdD]",
					"name": "constant.character.class.regexp.awk"
				},
				{
					"match": "\\\\[0bfnrtv]",
					"name": "constant.character.escape.character.regexp.awk"
				},
				{
					"match": "\\\\c[A-Za-z]",
					"name": "constant.character.control.regexp.awk"
				},
				{ "include": "#unicode" },
				{
					"match": "(\\\\).",
					"captures": { "1": { "name": "constant.character.escape.backslash.regexp.awk" } }
				}
			]
		},
		"unicode": {
			"comment": "Unicode requires flag u or v to be active",
			"patterns": [
				{
					"match": "\\\\u{(0*\\h{4,5})}",
					"name": "meta.embedded.character.numeric.unicode.regexp.awk",
					"captures": {
						"0": { "name": "constant.character.numeric.regexp.awk" },
						"1": { "name": "constant.numeric.regexp.awk" }
					}
				},
				{
					"comment": "https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Regular_expressions/Unicode_character_class_escape#syntax",
					"begin": "\\\\[Pp]{",
					"end": "}|(?=/)|$",
					"captures": { "0": { "name": "constant.character.class.property.regexp.awk" } },
					"name": "meta.embedded.character.class.property.regexp.awk",
					"contentName": "string.regexp.awk",
					"patterns": [
						{
							"match": "(=)([a-zA-Z0-9_]+)",
							"captures": {
								"1": { "name": "punctuation.definition.property.value.regexp.awk" },
								"2": { "name": "variable.other.value.regexp.awk" }
							}
						},
						{
							"match": "[a-zA-Z_]+",
							"name": "variable.other.constant.property.regexp.awk"
						}
					]
				}
			]
		}
	}
}
